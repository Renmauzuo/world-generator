{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES2015",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "docs/scripts",
    "rootDir": "src/scripts",
    "sourceMap": true
  },
  "include": ["src/scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
